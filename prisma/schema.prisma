generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CLIENT
  PROVIDER
}

enum OrganizationType {
  CLIENT
  PROVIDER
  ADMIN
}

enum OrderStatus {
  SENT
  RECEIVED_BY_PROVIDER
  IN_PROCESS
  SHIPPED_TO_FINAL
  CANCELLED
}

enum DestinationType {
  CLIENT_WAREHOUSE
  FINAL_CLIENT
}

enum ShippingType {
  NATIONAL
  INTERNATIONAL
}

enum PriceType {
  FIXED
  PER_KG
}

enum DocumentType {
  FICHA_TECNICA
  FOLLETO_INFORMATIVO
}

enum VariantPresentation {
  BASE
  LONCHEADO
  PLATEADO
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  passwordHash   String
  name           String
  phone          String?
  role           Role
  active         Boolean       @default(true)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  ordersCreated  Order[]       @relation("OrderCreatedBy")
  statusEvents   OrderStatusEvent[]
  activityLogs   UserActivityLog[]
  catalogNotificationsActed CatalogNotification[] @relation("CatalogNotificationActor")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Organization {
  id              String           @id @default(cuid())
  type            OrganizationType
  name            String
  street          String?
  city            String?
  postalCode      String?
  country         String           @default("España")
  users           User[]
  orders          Order[]          @relation("ClientOrders")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Product {
  id              String           @id @default(cuid())
  name            String
  galvanReference String           @default("")
  description     String?
  active          Boolean          @default(true)
  variants        ProductVariant[]
  documents       ProductDocument[]
  catalogNotifications CatalogNotification[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model ProductVariant {
  id              String               @id @default(cuid())
  productId       String
  product         Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  name            String
  presentation    VariantPresentation  @default(BASE)
  galvanReference String               @default("")
  unitLabel       String
  priceCents   Int
  priceType    PriceType            @default(FIXED)
  vatRate      Float                @default(0.10)
  active       Boolean              @default(true)
  orderLines   OrderLine[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model ProductDocument {
  id        String       @id @default(cuid())
  productId String
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  docType   DocumentType @default(FICHA_TECNICA)
  title     String?
  fileUrl   String
  createdAt DateTime     @default(now())
}

model Order {
  id                String             @id @default(cuid())
  orderNumber       String             @unique
  cancellationNumber String?           @unique
  clientOrgId       String
  clientOrg         Organization       @relation("ClientOrders", fields: [clientOrgId], references: [id])
  createdByUserId   String
  createdBy         User               @relation("OrderCreatedBy", fields: [createdByUserId], references: [id])
  status            OrderStatus        @default(SENT)
  destinationType   DestinationType
  destName          String?
  destStreet        String?
  destCity          String?
  destPostalCode    String?
  destCountry       String             @default("España")
  destEmail         String?
  finalClientFirstName     String?
  finalClientLastName      String?
  finalClientStreet        String?
  finalClientCity          String?
  finalClientPostalCode    String?
  finalClientCountry       String?
  finalClientPhone         String?
  finalClientPhoneSecondary String?
  finalClientEmail         String?
  shippingType      ShippingType
  shippingCostCents Int
  shippingServiceId String?
  shippingService   ShippingRate? @relation(fields: [shippingServiceId], references: [id], onDelete: SetNull)
  shippingLabel     String?
  subtotalCents     Int
  vatCents          Int                @default(0)
  totalCents        Int
  carrierCompany         String?
  carrierTrackingNumber  String?
  carrierTrackingUrl     String?
  carrierPhone           String?
  lines             OrderLine[]
  statusEvents      OrderStatusEvent[]
  trackingToken     TrackingToken?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model OrderLine {
  id               String         @id @default(cuid())
  orderId          String
  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId        String
  variant          ProductVariant @relation(fields: [variantId], references: [id])
  quantity         Float
  unitPriceCents   Int
  lineTotalCents   Int
  /** Peso real en kg (jamón entero, lomito) */
  actualWeightKg   Float?
  /** Paquetes o platos reales (loncheado, plateado) */
  actualPieceCount Float?
  /** Nº identificación interna Galvan (opcional) */
  galvanInternalId String?
}

model OrderStatusEvent {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  note      String?
  createdByUserId String?
  createdBy User?       @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt DateTime    @default(now())
}

model UserActivityLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String
  summary    String
  detail     String?
  entityType String?
  entityId   String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
}

model TrackingToken {
  id        String   @id @default(cuid())
  orderId   String   @unique
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime?
  createdAt DateTime @default(now())
}

model ShippingRate {
  id         String       @id @default(cuid())
  type       ShippingType
  label      String
  priceCents Int
  supplier   String       @default("")
  isDefault  Boolean      @default(false)
  active     Boolean      @default(true)
  sortOrder  Int          @default(0)
  orders     Order[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([type, active])
}

model CatalogNotification {
  id          String   @id @default(cuid())
  type        String
  summary     String
  detail      String?
  productId   String?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  actorUserId String
  actor       User     @relation("CatalogNotificationActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([read, createdAt])
}
